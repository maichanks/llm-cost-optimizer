# LLM Cost Optimizer - Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API key (required for cost tracking)
OPENROUTER_API_KEY=

# Alert configuration
ALERT_CHANNEL=feishu  # or telegram, slack
ALERT_TARGET=ou_OPEN_ID

# Budget thresholds (in USD)
BUDGET_WARNING=10    # Send warning when daily cost exceeds
BUDGET_CRITICAL=50   # Send critical alert when daily cost exceeds

# Redis configuration (for caching)
REDIS_URL=redis://localhost:6379

# Log directory (where OpenClaw stores LLM logs)
LOG_DIR=./logs

# Optional: Slack webhook URL (if using slack channel)
# SLACK_WEBHOOK_URL=
